{
  "name": "dietie-telegram-worker",
  "version": "1.0.0",
  "private": true,
  "description": "dietie Telegram bot on Cloudflare Workers + D1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-login": "wrangler login",
    "d1-create": "wrangler d1 create dietie_bot_db",
    "d1-migrate-local": "wrangler d1 migrations apply dietie_bot_db --local",
    "d1-migrate-remote": "wrangler d1 migrations apply dietie_bot_db --remote",
    "types": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "typescript": "latest",
    "wrangler": "latest"
  }
}
